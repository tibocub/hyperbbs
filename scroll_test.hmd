:::script
const btnA = hypersite.getElementById('btn-a')
const output = hypersite.getElementById('output')
let clicks = 0

btnA.on('press', () => {
  clicks++
  output.setText('Button clicked ' + clicks + ' time(s) — scroll position preserved!')
  console.log('click', clicks)
})
:::
